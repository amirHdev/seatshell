import { LineEdit, ScrollView } from "std-widgets.slint";
import { AppRow } from "app-row.slint";
import { ShellTheme } from "shell-theme.slint";
import { ShellAction, ShellPill } from "shell-widgets.slint";

export struct LauncherApp {
    id: string,
    name: string,
    detail: string,
    icon_text: string,
    icon: image,
    selected: bool,
    favorite: bool,
    running_count: int,
}

export component Launcher inherits Rectangle {
    in property <string> accent: "#4a90e2";
    in property <[LauncherApp]> apps;
    in property <[LauncherApp]> featured-apps;
    in property <[LauncherApp]> recent-apps;
    in property <string> query;
    in property <int> app-count;

    callback launch-app(string);
    callback search-changed(string);
    callback accept-search();
    callback move-selection(int);
    callback toggle-favorite(string);
    callback close();

    background: #06101ae6;
    in property <bool> wide: root.width >= 960px;

    Rectangle {
        x: min(16px, root.width * 0.025);
        y: min(16px, root.height * 0.025);
        width: min(root.width - 32px, 1000px);
        height: min(root.height - 32px, 640px);
        background: ShellTheme.background-elevated;
        border-radius: ShellTheme.radius-lg * 1px;
        border-width: 1px;
        border-color: ShellTheme.outline;

        VerticalLayout {
            padding: 14px;
            spacing: 12px;

            HorizontalLayout {
                spacing: 12px;
                alignment: center;

                VerticalLayout {
                    spacing: 2px;
                    horizontal-stretch: 1;

                    Text {
                        text: "Applications";
                        color: ShellTheme.text-primary;
                        font-size: 18px;
                        font-weight: 800;
                    }

                    Text {
                        text: "Search, launch, and pin tools.";
                        color: ShellTheme.text-secondary;
                        font-size: 12px;
                    }
                }

                ShellPill {
                    label: root.app-count + " apps";
                    compact: true;
                }

                ShellAction {
                    label: "Close";
                    icon-text: "X";
                    compact: true;
                    clicked => {
                        root.close();
                    }
                }
            }

            LineEdit {
                text: root.query;
                placeholder-text: "Search applications";
                edited(text) => {
                    root.search-changed(text);
                }
                accepted(text) => {
                    root.accept-search();
                }
                key-pressed(event) => {
                    if (event.text == Key.UpArrow) {
                        root.move-selection(-1);
                        accept
                    } else if (event.text == Key.DownArrow) {
                        root.move-selection(1);
                        accept
                    } else if (event.text == Key.Escape) {
                        root.close();
                        accept
                    } else {
                        reject
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: ShellTheme.outline;
            }

            if root.wide: HorizontalLayout {
                vertical-stretch: 1;
                spacing: 14px;

                Rectangle {
                    width: 268px;
                    background: transparent;

                    ScrollView {
                        width: parent.width;
                        height: parent.height;
                        viewport-width: self.width;

                        VerticalLayout {
                            spacing: 14px;

                            if root.featured-apps.length > 0: Rectangle {
                                background: transparent;

                                VerticalLayout {
                                    spacing: 8px;

                                    Text {
                                        text: "Pinned";
                                        color: ShellTheme.text-primary;
                                        font-size: 14px;
                                        font-weight: 800;
                                    }

                                    for app in root.featured-apps: AppRow {
                                        name: app.name;
                                        detail: app.detail;
                                        icon-text: app.icon_text;
                                        icon: app.icon;
                                        favorite: app.favorite;
                                        running-count: app.running_count;
                                        accent: root.accent;
                                        show-favorite-toggle: true;
                                        clicked => {
                                            root.launch-app(app.id);
                                        }
                                        toggle-favorite => {
                                            root.toggle-favorite(app.id);
                                        }
                                    }
                                }
                            }

                            if root.recent-apps.length > 0: Rectangle {
                                background: transparent;

                                VerticalLayout {
                                    spacing: 8px;

                                    Text {
                                        text: "Recent";
                                        color: ShellTheme.text-primary;
                                        font-size: 14px;
                                        font-weight: 800;
                                    }

                                    for app in root.recent-apps: AppRow {
                                        name: app.name;
                                        detail: app.detail;
                                        icon-text: app.icon_text;
                                        icon: app.icon;
                                        favorite: app.favorite;
                                        accent: root.accent;
                                        clicked => {
                                            root.launch-app(app.id);
                                        }
                                        toggle-favorite => {
                                            root.toggle-favorite(app.id);
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    width: 1px;
                    vertical-stretch: 1;
                    background: ShellTheme.outline;
                }

                Rectangle {
                    horizontal-stretch: 1;
                    background: transparent;

                    VerticalLayout {
                        spacing: 10px;

                        Text {
                            text: root.query == "" ? "Browse all applications" : "Search results";
                            color: ShellTheme.text-primary;
                            font-size: 15px;
                            font-weight: 800;
                        }

                        if root.app-count == 0: Rectangle {
                            height: 72px;
                            background: ShellTheme.surface;
                            border-radius: ShellTheme.radius-md * 1px;
                            border-width: 1px;
                            border-color: ShellTheme.outline;

                            Text {
                                text: "No matching applications";
                                color: ShellTheme.text-secondary;
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        ScrollView {
                            vertical-stretch: 1;
                            viewport-width: self.width;

                            VerticalLayout {
                                spacing: 6px;

                                for app in root.apps: AppRow {
                                    name: app.name;
                                    detail: app.detail;
                                        icon-text: app.icon_text;
                                        icon: app.icon;
                                        selected: app.selected;
                                        favorite: app.favorite;
                                        running-count: app.running_count;
                                        show-favorite-toggle: true;
                                    accent: root.accent;
                                    clicked => {
                                        root.launch-app(app.id);
                                    }
                                    toggle-favorite => {
                                        root.toggle-favorite(app.id);
                                    }
                                }
                            }
                        }
                    }
                }
            }

            if !root.wide: ScrollView {
                vertical-stretch: 1;
                viewport-width: self.width;

                VerticalLayout {
                    spacing: 16px;

                    if root.featured-apps.length > 0: Rectangle {
                        background: transparent;

                        VerticalLayout {
                            spacing: 8px;

                            Text {
                                text: "Pinned";
                                color: ShellTheme.text-primary;
                                font-size: 14px;
                                font-weight: 800;
                            }

                            for app in root.featured-apps: AppRow {
                                name: app.name;
                                detail: app.detail;
                                icon-text: app.icon_text;
                                icon: app.icon;
                                favorite: app.favorite;
                                running-count: app.running_count;
                                accent: root.accent;
                                show-favorite-toggle: true;
                                clicked => {
                                    root.launch-app(app.id);
                                }
                                toggle-favorite => {
                                    root.toggle-favorite(app.id);
                                }
                            }
                        }
                    }

                    if root.recent-apps.length > 0: Rectangle {
                        background: transparent;

                        VerticalLayout {
                            spacing: 8px;

                            Text {
                                text: "Recent";
                                color: ShellTheme.text-primary;
                                font-size: 14px;
                                font-weight: 800;
                            }

                            for app in root.recent-apps: AppRow {
                                name: app.name;
                                detail: app.detail;
                                icon-text: app.icon_text;
                                icon: app.icon;
                                favorite: app.favorite;
                                running-count: app.running_count;
                                accent: root.accent;
                                clicked => {
                                    root.launch-app(app.id);
                                }
                                toggle-favorite => {
                                    root.toggle-favorite(app.id);
                                }
                            }
                        }
                    }

                    Rectangle {
                        background: transparent;

                        VerticalLayout {
                            spacing: 8px;

                            Text {
                                text: root.query == "" ? "Browse all applications" : "Search results";
                                color: ShellTheme.text-primary;
                                font-size: 14px;
                                font-weight: 800;
                            }

                            if root.app-count == 0: Rectangle {
                                height: 72px;
                                background: ShellTheme.surface;
                                border-radius: ShellTheme.radius-md * 1px;
                                border-width: 1px;
                                border-color: ShellTheme.outline;

                                Text {
                                    text: "No matching applications";
                                    color: ShellTheme.text-secondary;
                                    font-size: 14px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }

                            for app in root.apps: AppRow {
                                name: app.name;
                                detail: app.detail;
                                icon-text: app.icon_text;
                                icon: app.icon;
                                selected: app.selected;
                                favorite: app.favorite;
                                running-count: app.running_count;
                                show-favorite-toggle: true;
                                accent: root.accent;
                                clicked => {
                                    root.launch-app(app.id);
                                }
                                toggle-favorite => {
                                    root.toggle-favorite(app.id);
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
