import { LineEdit, ScrollView } from "std-widgets.slint";
import { AppRow } from "app-row.slint";
import { ShellTheme } from "shell-theme.slint";
import { ShellAction, ShellPill } from "shell-widgets.slint";

export struct LauncherApp {
    id: string,
    name: string,
    detail: string,
    icon_text: string,
    icon: image,
    selected: bool,
    favorite: bool,
    running_count: int,
}

export component Launcher inherits Rectangle {
    in property <string> accent: "#4a90e2";
    in property <[LauncherApp]> apps;
    in property <[LauncherApp]> featured-apps;
    in property <[LauncherApp]> recent-apps;
    in property <string> query;
    in property <int> app-count;
    in property <bool> compact: root.width < 760px;
    in property <bool> wide: root.width >= 1020px;

    callback launch-app(string);
    callback search-changed(string);
    callback accept-search();
    callback move-selection(int);
    callback toggle-favorite(string);
    callback close();

    background: ShellTheme.background-veil;

    Rectangle {
        x: root.width - 280px;
        y: 24px;
        width: 260px;
        height: 260px;
        background: ShellTheme.ambient-secondary;
        border-radius: 999px;
        opacity: 0.28;
    }

    Rectangle {
        x: 18px;
        y: root.height - 220px;
        width: 220px;
        height: 220px;
        background: ShellTheme.ambient-primary;
        border-radius: 999px;
        opacity: 0.24;
    }

    Rectangle {
        x: max(10px, (root.width - min(root.width - 20px, 1080px)) / 2);
        y: max(10px, (root.height - min(root.height - 20px, 680px)) / 2);
        width: min(root.width - 20px, 1080px);
        height: min(root.height - 20px, 680px);
        background: ShellTheme.background-elevated;
        border-radius: ShellTheme.radius-xl * 1px;
        border-width: 1px;
        border-color: ShellTheme.outline-strong;

        VerticalLayout {
            padding: root.compact ? 12px : 16px;
            spacing: 12px;

            if !root.compact: HorizontalLayout {
                spacing: 12px;
                alignment: center;

                VerticalLayout {
                    spacing: 3px;
                    horizontal-stretch: 1;

                    Text {
                        text: "Application constellation";
                        color: ShellTheme.text-primary;
                        font-size: 20px;
                        font-weight: 800;
                    }

                    Text {
                        text: "Search, launch, and keep your closest tools in a shelf that feels curated rather than crowded.";
                        color: ShellTheme.text-secondary;
                        font-size: 12px;
                    }
                }

                ShellPill {
                    label: root.app-count + " results";
                    compact: true;
                }

                ShellAction {
                    label: "Close";
                    icon-text: "X";
                    compact: true;
                    clicked => {
                        root.close();
                    }
                }
            }

            if root.compact: VerticalLayout {
                spacing: 8px;

                Text {
                    text: "Application constellation";
                    color: ShellTheme.text-primary;
                    font-size: 18px;
                    font-weight: 800;
                }

                Text {
                    text: "Search, launch, and keep your closest tools in a shelf that feels curated rather than crowded.";
                    color: ShellTheme.text-secondary;
                    font-size: 11px;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 8px;

                    ShellPill {
                        label: root.app-count + " results";
                        compact: true;
                    }

                    ShellAction {
                        label: "Close";
                        icon-text: "X";
                        compact: true;
                        clicked => {
                            root.close();
                        }
                    }
                }
            }

            Rectangle {
                background: ShellTheme.surface;
                border-radius: ShellTheme.radius-lg * 1px;
                border-width: 1px;
                border-color: ShellTheme.outline;

                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;

                    Text {
                        text: root.query == "" ? "Start with a name, category, or command hint." : "Refine the field, then press Enter to launch the selected app.";
                        color: ShellTheme.text-secondary;
                        font-size: 11px;
                    }

                    LineEdit {
                        text: root.query;
                        placeholder-text: "Search applications";
                        edited(text) => {
                            root.search-changed(text);
                        }
                        accepted(text) => {
                            root.accept-search();
                        }
                        key-pressed(event) => {
                            if (event.text == Key.UpArrow) {
                                root.move-selection(-1);
                                accept
                            } else if (event.text == Key.DownArrow) {
                                root.move-selection(1);
                                accept
                            } else if (event.text == Key.Escape) {
                                root.close();
                                accept
                            } else {
                                reject
                            }
                        }
                    }
                }
            }

            if root.wide: HorizontalLayout {
                vertical-stretch: 1;
                spacing: 14px;

                Rectangle {
                    width: 296px;
                    background: ShellTheme.surface;
                    border-radius: ShellTheme.radius-xl * 1px;
                    border-width: 1px;
                    border-color: ShellTheme.outline;

                    ScrollView {
                        width: parent.width;
                        height: parent.height;
                        viewport-width: self.width;

                        VerticalLayout {
                            padding: 14px;
                            spacing: 14px;

                            Rectangle {
                                background: ShellTheme.background-elevated;
                                border-radius: ShellTheme.radius-lg * 1px;
                                border-width: 1px;
                                border-color: ShellTheme.outline;

                                VerticalLayout {
                                    padding: 12px;
                                    spacing: 8px;

                                    Text {
                                        text: "Intent";
                                        color: ShellTheme.text-primary;
                                        font-size: 14px;
                                        font-weight: 800;
                                    }

                                    Text {
                                        text: "The launcher should feel like a composed shelf: a few trusted anchors, a quick search path, and no visual panic.";
                                        color: ShellTheme.text-secondary;
                                        font-size: 11px;
                                        wrap: word-wrap;
                                    }
                                }
                            }

                            if root.featured-apps.length > 0: Rectangle {
                                background: transparent;

                                VerticalLayout {
                                    spacing: 8px;

                                    Text {
                                        text: "Pinned";
                                        color: ShellTheme.text-primary;
                                        font-size: 14px;
                                        font-weight: 800;
                                    }

                                    for app in root.featured-apps: AppRow {
                                        name: app.name;
                                        detail: app.detail;
                                        icon-text: app.icon_text;
                                        icon: app.icon;
                                        favorite: app.favorite;
                                        running-count: app.running_count;
                                        accent: root.accent;
                                        show-favorite-toggle: true;
                                        clicked => {
                                            root.launch-app(app.id);
                                        }
                                        toggle-favorite => {
                                            root.toggle-favorite(app.id);
                                        }
                                    }
                                }
                            }

                            if root.recent-apps.length > 0: Rectangle {
                                background: transparent;

                                VerticalLayout {
                                    spacing: 8px;

                                    Text {
                                        text: "Recent";
                                        color: ShellTheme.text-primary;
                                        font-size: 14px;
                                        font-weight: 800;
                                    }

                                    for app in root.recent-apps: AppRow {
                                        name: app.name;
                                        detail: app.detail;
                                        icon-text: app.icon_text;
                                        icon: app.icon;
                                        favorite: app.favorite;
                                        running-count: app.running_count;
                                        accent: root.accent;
                                        clicked => {
                                            root.launch-app(app.id);
                                        }
                                        toggle-favorite => {
                                            root.toggle-favorite(app.id);
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                    background: ShellTheme.surface;
                    border-radius: ShellTheme.radius-xl * 1px;
                    border-width: 1px;
                    border-color: ShellTheme.outline;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 10px;

                        Text {
                            text: root.query == "" ? "All applications" : "Search results";
                            color: ShellTheme.text-primary;
                            font-size: 16px;
                            font-weight: 800;
                        }

                        Text {
                            text: root.query == "" ? "Browse the full field or start typing to narrow the constellation." : "The selected row responds to Enter, and the pin toggle keeps important tools nearby.";
                            color: ShellTheme.text-secondary;
                            font-size: 11px;
                        }

                        if root.app-count == 0: Rectangle {
                            background: ShellTheme.background-elevated;
                            border-radius: ShellTheme.radius-lg * 1px;
                            border-width: 1px;
                            border-color: ShellTheme.outline;

                            VerticalLayout {
                                padding: 16px;
                                spacing: 6px;
                                alignment: center;

                                Text {
                                    text: root.query == "" ? "No applications discovered yet" : "No matching applications";
                                    color: ShellTheme.text-primary;
                                    font-size: 15px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                }

                                Text {
                                    text: root.query == "" ? "SeatShell did not find desktop entries for this session. Check the install path or session environment." : "Try a broader term, clear the query, or pin a frequent app from the browse view.";
                                    color: ShellTheme.text-secondary;
                                    font-size: 11px;
                                    wrap: word-wrap;
                                    horizontal-alignment: center;
                                }
                            }
                        }

                        ScrollView {
                            vertical-stretch: 1;
                            viewport-width: self.width;

                            VerticalLayout {
                                spacing: 8px;

                                for app in root.apps: AppRow {
                                    name: app.name;
                                    detail: app.detail;
                                    icon-text: app.icon_text;
                                    icon: app.icon;
                                    selected: app.selected;
                                    favorite: app.favorite;
                                    running-count: app.running_count;
                                    show-favorite-toggle: true;
                                    accent: root.accent;
                                    clicked => {
                                        root.launch-app(app.id);
                                    }
                                    toggle-favorite => {
                                        root.toggle-favorite(app.id);
                                    }
                                }
                            }
                        }
                    }
                }
            }

            if !root.wide: ScrollView {
                vertical-stretch: 1;
                viewport-width: self.width;

                VerticalLayout {
                    spacing: 14px;

                    Rectangle {
                        background: ShellTheme.surface;
                        border-radius: ShellTheme.radius-xl * 1px;
                        border-width: 1px;
                        border-color: ShellTheme.outline;

                        VerticalLayout {
                            padding: 14px;
                            spacing: 8px;

                            Text {
                                text: "Pinned and recent";
                                color: ShellTheme.text-primary;
                                font-size: 15px;
                                font-weight: 800;
                            }

                            Text {
                                text: "Keep favorites close and use the search box when the list gets crowded.";
                                color: ShellTheme.text-secondary;
                                font-size: 11px;
                                wrap: word-wrap;
                            }

                            if root.featured-apps.length > 0: Rectangle {
                                background: transparent;

                                VerticalLayout {
                                    spacing: 8px;

                                    Text {
                                        text: "Pinned";
                                        color: ShellTheme.text-secondary;
                                        font-size: 12px;
                                        font-weight: 700;
                                    }

                                    for app in root.featured-apps: AppRow {
                                        name: app.name;
                                        detail: app.detail;
                                        icon-text: app.icon_text;
                                        icon: app.icon;
                                        favorite: app.favorite;
                                        running-count: app.running_count;
                                        accent: root.accent;
                                        show-favorite-toggle: true;
                                        clicked => {
                                            root.launch-app(app.id);
                                        }
                                        toggle-favorite => {
                                            root.toggle-favorite(app.id);
                                        }
                                    }
                                }
                            }

                            if root.recent-apps.length > 0: Rectangle {
                                background: transparent;

                                VerticalLayout {
                                    spacing: 8px;

                                    Text {
                                        text: "Recent";
                                        color: ShellTheme.text-secondary;
                                        font-size: 12px;
                                        font-weight: 700;
                                    }

                                    for app in root.recent-apps: AppRow {
                                        name: app.name;
                                        detail: app.detail;
                                        icon-text: app.icon_text;
                                        icon: app.icon;
                                        favorite: app.favorite;
                                        running-count: app.running_count;
                                        accent: root.accent;
                                        clicked => {
                                            root.launch-app(app.id);
                                        }
                                        toggle-favorite => {
                                            root.toggle-favorite(app.id);
                                        }
                                    }
                                }
                            }
                        }
                    }

                    Rectangle {
                        background: ShellTheme.surface;
                        border-radius: ShellTheme.radius-xl * 1px;
                        border-width: 1px;
                        border-color: ShellTheme.outline;

                        VerticalLayout {
                            padding: 14px;
                            spacing: 8px;

                            Text {
                                text: root.query == "" ? "Browse all applications" : "Search results";
                                color: ShellTheme.text-primary;
                                font-size: 15px;
                                font-weight: 800;
                            }

                            if root.app-count == 0: Rectangle {
                                background: ShellTheme.background-elevated;
                                border-radius: ShellTheme.radius-lg * 1px;
                                border-width: 1px;
                                border-color: ShellTheme.outline;

                                VerticalLayout {
                                    padding: 16px;
                                    spacing: 6px;
                                    alignment: center;

                                    Text {
                                        text: root.query == "" ? "No applications discovered yet" : "No matching applications";
                                        color: ShellTheme.text-primary;
                                        font-size: 15px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                    }

                                    Text {
                                        text: root.query == "" ? "SeatShell did not find desktop entries for this session. Check the install path or session environment." : "Try a broader term or clear the current query.";
                                        color: ShellTheme.text-secondary;
                                        font-size: 11px;
                                        wrap: word-wrap;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            for app in root.apps: AppRow {
                                name: app.name;
                                detail: app.detail;
                                icon-text: app.icon_text;
                                icon: app.icon;
                                selected: app.selected;
                                favorite: app.favorite;
                                running-count: app.running_count;
                                show-favorite-toggle: true;
                                accent: root.accent;
                                clicked => {
                                    root.launch-app(app.id);
                                }
                                toggle-favorite => {
                                    root.toggle-favorite(app.id);
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
