import { UserCard } from "user-card.slint";
import { Button } from "std-widgets.slint";

export struct UserSession {
    username: string,
    state: string,
    action: string,
}

export component Overview inherits Rectangle {
    in property <string> accent: "#4a90e2";
    in property <[UserSession]> sessions;
    in property <string> status-text;
    callback close();
    background: #07111bf4;

    VerticalLayout {
        padding: 28px;
        spacing: 18px;

        HorizontalLayout {
            spacing: 12px;
            alignment: center;

            Text {
                text: "SingleSeat Overview";
                color: #f4f7fb;
                font-size: 30px;
                font-weight: 700;
                horizontal-stretch: 1;
            }

            Text {
                text: root.status-text;
                color: #93a4b8;
                font-size: 13px;
            }

            Button {
                text: "Close";
                clicked => {
                    root.close();
                }
            }
        }

        HorizontalLayout {
            height: 44px;
            spacing: 10px;

            Rectangle {
                background: #101a24;
                border-radius: 6px;
                border-width: 1px;
                border-color: #28394b;
                horizontal-stretch: 1;

                Text {
                    text: "Read-only session discovery is active";
                    color: #cbd5e1;
                    font-size: 14px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Rectangle {
                width: 240px;
                background: #101a24;
                border-radius: 6px;
                border-width: 1px;
                border-color: #28394b;

                Text {
                    text: root.sessions.length + " visible sessions";
                    color: #cbd5e1;
                    font-size: 14px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 18px;

            for session in root.sessions: UserCard {
                username: session.username;
                state: session.state;
                action: session.action;
                accent: root.accent;
            }
        }

        Rectangle {
            height: 42px;
            background: #101a24;
            border-radius: 6px;
            border-width: 1px;
            border-color: #28394b;

            Text {
                text: "Privileged actions are held until authorization and audit logging are connected.";
                color: #9fb0c2;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
