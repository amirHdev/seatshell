import { UserCard } from "user-card.slint";
import { ScrollView } from "std-widgets.slint";
import { ShellTheme } from "shell-theme.slint";
import { ShellAction, ShellPill } from "shell-widgets.slint";

export struct UserSession {
    username: string,
    state: string,
    action: string,
    selected: bool,
}

export component Overview inherits FocusScope {
    in property <string> accent: "#4a90e2";
    in property <[UserSession]> sessions;
    in property <string> status-text;
    in property <bool> compact: root.width < 860px;
    in property <bool> wide: root.width >= 1120px;
    callback move-selection(int);
    callback activate-current-session();
    callback close();

    key-pressed(event) => {
        if (event.text == Key.UpArrow) {
            root.move-selection(-1);
            accept
        } else if (event.text == Key.DownArrow) {
            root.move-selection(1);
            accept
        } else if (event.text == Key.Escape) {
            root.close();
            accept
        } else if (event.text == Key.Return) {
            root.activate-current-session();
            accept
        } else {
            reject
        }
    }

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: ShellTheme.background;

        Rectangle {
            x: -80px;
            y: 28px;
            width: 260px;
            height: 260px;
            background: ShellTheme.ambient-primary;
            border-radius: 999px;
            opacity: 0.26;
        }

        Rectangle {
            x: root.width - 220px;
            y: root.height - 240px;
            width: 280px;
            height: 280px;
            background: ShellTheme.ambient-secondary;
            border-radius: 999px;
            opacity: 0.24;
        }

        VerticalLayout {
            padding: 14px;
            spacing: 12px;

            Rectangle {
                height: root.compact ? 168px : 128px;
                background: ShellTheme.background-elevated;
                border-radius: ShellTheme.radius-xl * 1px;
                border-width: 1px;
                border-color: ShellTheme.outline;

                if !root.compact: HorizontalLayout {
                    padding: 16px;
                    spacing: 12px;
                    alignment: center;

                    VerticalLayout {
                        spacing: 4px;
                        horizontal-stretch: 1;

                        Text {
                            text: "SingleSeat Overview";
                            color: ShellTheme.text-primary;
                            font-size: 20px;
                            font-weight: 800;
                        }

                        Text {
                            text: "A calmer readout of local sessions, their current state, and the next action you can safely take.";
                            color: ShellTheme.text-secondary;
                            font-size: 12px;
                            wrap: word-wrap;
                        }

                        Text {
                            text: "Concept before clutter. " + root.status-text;
                            color: ShellTheme.text-muted;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }

                    ShellPill {
                        label: root.sessions.length + " sessions";
                        compact: true;
                    }

                    ShellAction {
                        label: "Activate";
                        icon-text: ">";
                        compact: true;
                        clicked => {
                            root.activate-current-session();
                        }
                    }

                    ShellAction {
                        label: "Close";
                        icon-text: "X";
                        compact: true;
                        clicked => {
                            root.close();
                        }
                    }
                }

                if root.compact: VerticalLayout {
                    padding: 14px;
                    spacing: 8px;

                    Text {
                        text: "SingleSeat Overview";
                        color: ShellTheme.text-primary;
                        font-size: 18px;
                        font-weight: 800;
                    }

                    Text {
                        text: "A calmer readout of local sessions, their current state, and the next action you can safely take.";
                        color: ShellTheme.text-secondary;
                        font-size: 11px;
                        wrap: word-wrap;
                    }

                    Text {
                        text: "Concept before clutter. " + root.status-text;
                        color: ShellTheme.text-muted;
                        font-size: 11px;
                        wrap: word-wrap;
                    }

                    HorizontalLayout {
                        spacing: 8px;

                        ShellPill {
                            label: root.sessions.length + " sessions";
                            compact: true;
                        }

                        ShellAction {
                            label: "Activate";
                            icon-text: ">";
                            compact: true;
                            clicked => {
                                root.activate-current-session();
                            }
                        }

                        ShellAction {
                            label: "Close";
                            icon-text: "X";
                            compact: true;
                            clicked => {
                                root.close();
                            }
                        }
                    }
                }
            }

            if root.wide: HorizontalLayout {
                vertical-stretch: 1;
                spacing: 12px;

                Rectangle {
                    width: 300px;
                    background: ShellTheme.surface;
                    border-radius: ShellTheme.radius-xl * 1px;
                    border-width: 1px;
                    border-color: ShellTheme.outline;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 12px;

                        Text {
                            text: "Reading the room";
                            color: ShellTheme.text-primary;
                            font-size: 15px;
                            font-weight: 800;
                        }

                        Text {
                            text: "This surface should explain who is active, who is idle, and what selection you are about to act on before SeatShell grows real admin controls.";
                            color: ShellTheme.text-secondary;
                            font-size: 11px;
                            wrap: word-wrap;
                        }

                        Rectangle {
                            background: ShellTheme.background-elevated;
                            border-radius: ShellTheme.radius-lg * 1px;
                            border-width: 1px;
                            border-color: ShellTheme.outline;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 8px;

                                Text {
                                    text: "Keyboard";
                                    color: ShellTheme.text-secondary;
                                    font-size: 12px;
                                    font-weight: 700;
                                }

                                Text {
                                    text: "Use Up and Down to move between sessions. Press Enter to activate the current selection.";
                                    color: ShellTheme.text-muted;
                                    font-size: 11px;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        Rectangle {
                            background: ShellTheme.background-elevated;
                            border-radius: ShellTheme.radius-lg * 1px;
                            border-width: 1px;
                            border-color: ShellTheme.outline;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 8px;

                                Text {
                                    text: "Direction";
                                    color: ShellTheme.text-secondary;
                                    font-size: 12px;
                                    font-weight: 700;
                                }

                                Text {
                                    text: "The next design pass should distinguish current, locked, and inactive sessions more clearly than a plain label alone.";
                                    color: ShellTheme.text-muted;
                                    font-size: 11px;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                            background: transparent;
                        }
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                    background: ShellTheme.surface;
                    border-radius: ShellTheme.radius-xl * 1px;
                    border-width: 1px;
                    border-color: ShellTheme.outline;

                    VerticalLayout {
                        padding: 14px;
                        spacing: 10px;

                        Text {
                            text: "Local sessions";
                            color: ShellTheme.text-primary;
                            font-size: 16px;
                            font-weight: 800;
                        }

                        if root.sessions.length == 0: Rectangle {
                            background: ShellTheme.background-elevated;
                            border-radius: ShellTheme.radius-lg * 1px;
                            border-width: 1px;
                            border-color: ShellTheme.outline;

                            VerticalLayout {
                                padding: 16px;
                                spacing: 6px;
                                alignment: center;

                                Text {
                                    text: "No sessions available";
                                    color: ShellTheme.text-primary;
                                    font-size: 15px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                }

                                Text {
                                    text: "SeatShell could not read session data. Start the admin service or switch to the development fallback.";
                                    color: ShellTheme.text-secondary;
                                    font-size: 11px;
                                    wrap: word-wrap;
                                    horizontal-alignment: center;
                                }
                            }
                        }

                        ScrollView {
                            vertical-stretch: 1;
                            viewport-width: self.width;

                            VerticalLayout {
                                spacing: 10px;

                                for session in root.sessions: UserCard {
                                    username: session.username;
                                    state: session.state;
                                    action: session.action;
                                    selected: session.selected;
                                    accent: root.accent;
                                }
                            }
                        }
                    }
                }
            }

            if !root.wide: Rectangle {
                vertical-stretch: 1;
                background: ShellTheme.surface;
                border-radius: ShellTheme.radius-xl * 1px;
                border-width: 1px;
                border-color: ShellTheme.outline;

                VerticalLayout {
                    padding: 14px;
                    spacing: 10px;

                    Text {
                        text: "Local sessions";
                        color: ShellTheme.text-primary;
                        font-size: 16px;
                        font-weight: 800;
                    }

                    Text {
                        text: "Use Up and Down to move through sessions. Press Enter to activate the selected session.";
                        color: ShellTheme.text-secondary;
                        font-size: 11px;
                        wrap: word-wrap;
                    }

                    if root.sessions.length == 0: Rectangle {
                        background: ShellTheme.background-elevated;
                        border-radius: ShellTheme.radius-lg * 1px;
                        border-width: 1px;
                        border-color: ShellTheme.outline;

                        VerticalLayout {
                            padding: 16px;
                            spacing: 6px;
                            alignment: center;

                            Text {
                                text: "No sessions available";
                                color: ShellTheme.text-primary;
                                font-size: 15px;
                                font-weight: 700;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: "SeatShell could not read session data. Start the admin service or switch to the development fallback.";
                                color: ShellTheme.text-secondary;
                                font-size: 11px;
                                wrap: word-wrap;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    ScrollView {
                        vertical-stretch: 1;
                        viewport-width: self.width;

                        VerticalLayout {
                            spacing: 10px;

                            for session in root.sessions: UserCard {
                                username: session.username;
                                state: session.state;
                                action: session.action;
                                selected: session.selected;
                                accent: root.accent;
                            }
                        }
                    }
                }
            }
        }
    }
}
