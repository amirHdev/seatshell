import { UserCard } from "user-card.slint";
import { ScrollView } from "std-widgets.slint";
import { ShellTheme } from "shell-theme.slint";
import { ShellAction, ShellPill } from "shell-widgets.slint";

export struct UserSession {
    username: string,
    state: string,
    action: string,
    selected: bool,
}

export component Overview inherits FocusScope {
    in property <string> accent: "#4a90e2";
    in property <[UserSession]> sessions;
    in property <string> status-text;
    callback move-selection(int);
    callback activate-current-session();
    callback close();

    key-pressed(event) => {
        if (event.text == Key.UpArrow) {
            root.move-selection(-1);
            accept
        } else if (event.text == Key.DownArrow) {
            root.move-selection(1);
            accept
        } else if (event.text == Key.Escape) {
            root.close();
            accept
        } else if (event.text == Key.Return) {
            root.activate-current-session();
            accept
        } else {
            reject
        }
    }

    Rectangle {
        width: parent.width;
        height: parent.height;
        background: ShellTheme.background;

        VerticalLayout {
            padding: 14px;
            spacing: 10px;

            HorizontalLayout {
                spacing: 12px;
                alignment: center;

                VerticalLayout {
                    spacing: 2px;
                    horizontal-stretch: 1;

                    Text {
                        text: "Sessions";
                        color: ShellTheme.text-primary;
                        font-size: 18px;
                        font-weight: 800;
                    }

                    Text {
                        text: "Select a local session and activate it.";
                        color: ShellTheme.text-secondary;
                        font-size: 12px;
                    }
                }

                ShellPill {
                    label: root.sessions.length + " sessions";
                    compact: true;
                }

                ShellAction {
                    label: "Enable";
                    icon-text: ">";
                    compact: true;
                    clicked => {
                        root.activate-current-session();
                    }
                }

                ShellAction {
                    label: "Close";
                    icon-text: "X";
                    compact: true;
                    clicked => {
                        root.close();
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: ShellTheme.outline;
            }

            ScrollView {
                vertical-stretch: 1;
                viewport-width: self.width;

                VerticalLayout {
                    spacing: 8px;

                    for session in root.sessions: UserCard {
                        username: session.username;
                        state: session.state;
                        action: session.action;
                        selected: session.selected;
                        accent: root.accent;
                    }
                }
            }

            Rectangle {
                height: 28px;
                background: transparent;

                Text {
                    text: "Arrow keys move through sessions. Press Enter or use Enable to activate the selected session.";
                    color: ShellTheme.text-secondary;
                    font-size: 11px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
