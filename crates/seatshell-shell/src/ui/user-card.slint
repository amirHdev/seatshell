export component UserCard inherits Rectangle {
    in property <string> username;
    in property <string> state;
    in property <string> action;
    in property <string> accent: "#4a90e2";

    width: 260px;
    height: 170px;
    background: #172130;
    border-radius: 8px;
    border-width: 1px;
    border-color: #314255;

    VerticalLayout {
        padding: 16px;
        spacing: 8px;

        Text {
            text: root.username;
            color: #f2f6fb;
            font-size: 22px;
            font-weight: 700;
        }

        Text {
            text: root.state;
            color: #aab6c5;
            font-size: 14px;
        }

        Rectangle {
            vertical-stretch: 1;
            background: #0f151e;
            border-radius: 6px;

            Text {
                text: root.action;
                color: #cbd5e1;
                font-size: 14px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
