import { Button } from "std-widgets.slint";

export component Panel inherits Rectangle {
    in property <string> accent: "#4a90e2";
    in property <string> clock-text;
    in property <string> status-text: "Ready";
    in property <bool> show-launcher: false;
    in property <bool> show-overview: false;
    callback toggle-launcher();
    callback toggle-overview();
    callback show-desktop();

    background: #0b1118;
    border-width: 1px;
    border-color: #1d2a36;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        alignment: center;

        Button {
            text: !root.show-launcher && !root.show-overview ? "Desktop *" : "Desktop";
            clicked => {
                root.show-desktop();
            }
        }

        Button {
            text: root.show-launcher ? "Apps *" : "Apps";
            clicked => {
                root.toggle-launcher();
            }
        }

        Button {
            text: root.show-overview ? "Sessions *" : "Sessions";
            clicked => {
                root.toggle-overview();
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            background: transparent;
        }

        Text {
            text: root.status-text;
            color: #c9d3df;
            font-size: 13px;
            horizontal-alignment: right;
        }

        Rectangle {
            width: 1px;
            height: 24px;
            background: #263443;
        }

        Text {
            text: root.clock-text;
            color: #f2f6fb;
            font-size: 14px;
            font-weight: 700;
        }
    }
}
