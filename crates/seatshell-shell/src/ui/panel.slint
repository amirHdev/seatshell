import { LauncherApp } from "launcher.slint";
import { ShellTheme } from "shell-theme.slint";
import { DockItem, ShellAction, ShellPill } from "shell-widgets.slint";

export component Panel inherits Rectangle {
    in property <string> accent: "#4a90e2";
    in property <string> clock-text;
    in property <string> status-text: "Ready";
    in property <string> network-text: "NET";
    in property <string> power-text: "PWR";
    in property <string> audio-text: "VOL ?";
    in property <[LauncherApp]> panel-apps;
    in property <int> app-count: 0;
    in property <int> session-count: 0;
    in property <int> notification-count: 0;
    in property <bool> show-launcher: false;
    in property <bool> show-overview: false;
    in property <bool> show-notifications: false;
    in property <bool> show-user-switcher: true;
    in property <bool> compact: root.width < 1200px;
    in property <bool> wide: root.width >= 1460px;
    callback toggle-launcher();
    callback toggle-overview();
    callback toggle-notifications();
    callback toggle-network();
    callback volume-down();
    callback volume-up();
    callback toggle-mute();
    callback show-desktop();
    callback launch-app(string);

    background: ShellTheme.background-elevated;
    border-width: 1px;
    border-color: ShellTheme.outline;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 8px;
        alignment: center;

        HorizontalLayout {
            spacing: 6px;
            alignment: center;

            Rectangle {
                width: 20px;
                height: 20px;
                background: ShellTheme.accent-soft;
                border-radius: ShellTheme.radius-sm * 1px;

                Text {
                    text: "S";
                    color: ShellTheme.text-primary;
                    font-size: 11px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            if !root.compact: Text {
                text: "SeatShell";
                color: ShellTheme.text-primary;
                font-size: 13px;
                font-weight: 800;
            }
        }

        Rectangle {
            width: 1px;
            height: 18px;
            background: ShellTheme.outline;
        }

        ShellAction {
            label: root.wide ? "Desktop" : "";
            icon-text: "D";
            active: !root.show-launcher && !root.show-overview;
            compact: true;
            clicked => {
                root.show-desktop();
            }
        }

        ShellAction {
            label: root.wide ? "Apps" : "";
            icon-text: "A";
            active: root.show-launcher;
            compact: true;
            clicked => {
                root.toggle-launcher();
            }
        }

        if root.show-user-switcher: ShellAction {
            label: root.wide ? "Sessions" : "";
            icon-text: "U";
            active: root.show-overview;
            compact: true;
            clicked => {
                root.toggle-overview();
            }
        }

        HorizontalLayout {
            horizontal-stretch: 1;
            spacing: 6px;

            Rectangle {
                horizontal-stretch: 1;
                background: transparent;
            }

            for app in root.panel-apps: DockItem {
                label: root.wide ? app.name : "";
                icon-text: app.icon_text;
                icon: app.icon;
                active: app.running_count > 0;
                running-count: app.running_count;
                clicked => {
                    root.launch-app(app.id);
                }
            }

            Rectangle {
                horizontal-stretch: 1;
                background: transparent;
            }
        }

        ShellAction {
            label: root.wide ? root.network-text : "";
            icon-text: "W";
            compact: true;
            clicked => {
                root.toggle-network();
            }
        }
        HorizontalLayout {
            spacing: 4px;

            ShellAction {
                label: "";
                icon-text: "-";
                compact: true;
                clicked => {
                    root.volume-down();
                }
            }

            ShellAction {
                label: root.wide ? root.audio-text : "";
                icon-text: "V";
                compact: true;
                clicked => {
                    root.toggle-mute();
                }
            }

            ShellAction {
                label: "";
                icon-text: "+";
                compact: true;
                clicked => {
                    root.volume-up();
                }
            }
        }
        if !root.compact: ShellPill { label: root.power-text; compact: true; }
        ShellAction {
            label: root.wide && root.notification-count > 0 ? root.notification-count + "" : "";
            icon-text: "N";
            active: root.show-notifications;
            compact: true;
            clicked => {
                root.toggle-notifications();
            }
        }
        if root.show-user-switcher: ShellPill { label: root.session-count + "S"; compact: true; }
        ShellPill { label: root.clock-text; tone: ShellTheme.accent-soft; compact: true; }
    }
}
