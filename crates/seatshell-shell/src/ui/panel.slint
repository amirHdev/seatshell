import { LauncherApp } from "launcher.slint";
import { ShellTheme } from "shell-theme.slint";
import { DockItem, ShellAction, ShellPill } from "shell-widgets.slint";

export component Panel inherits Rectangle {
    in property <string> accent: "#4a90e2";
    in property <string> clock-text;
    in property <string> status-text: "Ready";
    in property <string> network-text: "NET";
    in property <string> power-text: "PWR";
    in property <string> audio-text: "VOL ?";
    in property <[LauncherApp]> panel-apps;
    in property <int> app-count: 0;
    in property <int> session-count: 0;
    in property <int> notification-count: 0;
    in property <bool> show-launcher: false;
    in property <bool> show-overview: false;
    in property <bool> show-notifications: false;
    in property <bool> show-user-switcher: true;
    in property <bool> narrow: root.width < 980px;
    in property <bool> compact: root.width < 1280px;
    callback toggle-launcher();
    callback toggle-overview();
    callback toggle-notifications();
    callback toggle-network();
    callback volume-down();
    callback volume-up();
    callback toggle-mute();
    callback show-desktop();
    callback launch-app(string);

    background: #0d131dbf;
    border-width: 1px;
    border-color: ShellTheme.outline;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 10px;
        alignment: center;

        Rectangle {
            min-width: root.narrow ? 104px : 146px;
            height: parent.height;
            background: transparent;

            HorizontalLayout {
                padding-top: 6px;
                padding-bottom: 6px;
                spacing: 10px;
                alignment: center;

                Rectangle {
                    width: 28px;
                    height: 28px;
                    background: ShellTheme.accent;
                    border-radius: 999px;
                    border-width: 1px;
                    border-color: ShellTheme.accent;

                    Text {
                        text: "S";
                        color: #1a120d;
                        font-size: 13px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                if !root.narrow: VerticalLayout {
                    spacing: 1px;
                    horizontal-stretch: 1;

                    Text {
                        text: "SeatShell";
                        color: ShellTheme.text-primary;
                        font-size: 13px;
                        font-weight: 800;
                    }

                    Text {
                        text: root.status-text;
                        color: ShellTheme.text-secondary;
                        font-size: 10px;
                        overflow: elide;
                    }
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            height: parent.height;
            background: transparent;

            Rectangle {
                width: min(parent.width, root.narrow ? 236px : 300px);
                height: 52px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                background: #162130d9;
                border-radius: 999px;
                border-width: 1px;
                border-color: ShellTheme.outline;

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 12px;
                    alignment: center;

                    DockItem {
                        label: "";
                        icon-text: "D";
                        running-count: 0;
                        active: !root.show-launcher && !root.show-overview;
                        clicked => {
                            root.show-desktop();
                        }
                    }

                    DockItem {
                        label: "";
                        icon-text: "A";
                        running-count: 0;
                        active: root.show-launcher;
                        clicked => {
                            root.toggle-launcher();
                        }
                    }

                    if root.show-user-switcher: DockItem {
                        label: "";
                        icon-text: "U";
                        running-count: 0;
                        active: root.show-overview;
                        clicked => {
                            root.toggle-overview();
                        }
                    }

                    for app in root.panel-apps: DockItem {
                        label: "";
                        icon-text: app.icon_text;
                        icon: app.icon;
                        active: app.running_count > 0;
                        running-count: app.running_count;
                        clicked => {
                            root.launch-app(app.id);
                        }
                    }
                }
            }
        }

        Rectangle {
            min-width: root.narrow ? 96px : 150px;
            height: parent.height;
            background: transparent;

            Rectangle {
                width: root.narrow ? 92px : 130px;
                height: 36px;
                x: parent.width - self.width;
                y: (parent.height - self.height) / 2;
                background: #152030d9;
                border-radius: 999px;
                border-width: 1px;
                border-color: ShellTheme.outline;

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 4px;
                    alignment: center;

                    if !root.narrow: ShellAction {
                        label: "";
                        icon-text: "W";
                        compact: true;
                        clicked => {
                            root.toggle-network();
                        }
                    }

                    if !root.narrow: ShellAction {
                        label: "";
                        icon-text: "V";
                        compact: true;
                        clicked => {
                            root.toggle-mute();
                        }
                    }

                    ShellAction {
                        label: root.notification-count > 0 ? root.notification-count + "" : "";
                        icon-text: "N";
                        active: root.show-notifications;
                        compact: true;
                        clicked => {
                            root.toggle-notifications();
                        }
                    }

                    ShellPill {
                        label: root.clock-text;
                        tone: ShellTheme.surface-accent;
                        compact: true;
                    }
                }
            }
        }
    }
}
