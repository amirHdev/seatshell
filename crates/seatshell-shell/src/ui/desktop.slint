import { Button, ScrollView } from "std-widgets.slint";
import { LauncherApp } from "launcher.slint";
import { AppRow } from "app-row.slint";

export component Desktop inherits Rectangle {
    in property <string> accent: "#4a90e2";
    in property <string> clock-text;
    in property <string> status-text: "SeatShell ready";
    in property <[LauncherApp]> apps;

    callback show-launcher();
    callback show-overview();
    callback launch-app(string);

    background: #09111a;

    VerticalLayout {
        padding: 24px;
        spacing: 18px;

        HorizontalLayout {
            spacing: 16px;
            alignment: center;

            VerticalLayout {
                spacing: 4px;
                horizontal-stretch: 1;

                Text {
                    text: "SeatShell";
                    color: #f4f7fb;
                    font-size: 34px;
                    font-weight: 800;
                }

                Text {
                    text: root.status-text;
                    color: #9fb0c2;
                    font-size: 14px;
                }
            }

            Rectangle {
                width: 168px;
                height: 52px;
                background: #101a24;
                border-radius: 8px;
                border-width: 1px;
                border-color: #2a3a4d;

                Text {
                    text: root.clock-text;
                    color: #f2f6fb;
                    font-size: 19px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #243140;
        }

        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 18px;

            Rectangle {
                width: min(380px, max(260px, root.width * 0.28));
                background: #101a24;
                border-radius: 8px;
                border-width: 1px;
                border-color: #2b3d50;

                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;

                    Text {
                        text: "System";
                        color: #f2f6fb;
                        font-size: 22px;
                        font-weight: 700;
                    }

                    Rectangle {
                        height: 72px;
                        background: #0b141d;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: #243447;

                        VerticalLayout {
                            padding: 12px;
                            spacing: 4px;

                            Text {
                                text: "SingleSeat";
                                color: #dce6f1;
                                font-size: 15px;
                                font-weight: 700;
                            }

                            Text {
                                text: "Session overview and local application launch are ready.";
                                color: #9fb0c2;
                                font-size: 13px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    Button {
                        text: "Applications";
                        clicked => {
                            root.show-launcher();
                        }
                    }

                    Button {
                        text: "Sessions";
                        clicked => {
                            root.show-overview();
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                        background: transparent;
                    }
                }
            }

            Rectangle {
                background: #0e1721;
                border-radius: 8px;
                border-width: 1px;
                border-color: #29394c;
                horizontal-stretch: 1;

                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;

                    HorizontalLayout {
                        spacing: 10px;
                        alignment: center;

                        Text {
                            text: "Applications";
                            color: #f2f6fb;
                            font-size: 22px;
                            font-weight: 700;
                            horizontal-stretch: 1;
                        }

                        Button {
                            text: "Open Launcher";
                            clicked => {
                                root.show-launcher();
                            }
                        }
                    }

                    ScrollView {
                        vertical-stretch: 1;
                        viewport-width: self.width;

                        VerticalLayout {
                            spacing: 8px;

                            for app in root.apps: AppRow {
                                name: app.name;
                                exec: app.exec;
                                accent: root.accent;
                                clicked => {
                                    root.launch-app(app.id);
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
