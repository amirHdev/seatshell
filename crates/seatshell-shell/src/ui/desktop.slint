import { LauncherApp } from "launcher.slint";
import { ShellTheme } from "shell-theme.slint";
import { ShellAction, ShellPill } from "shell-widgets.slint";
import { ScrollView } from "std-widgets.slint";

export struct DesktopFile {
    path: string,
    name: string,
    detail: string,
}

component DesktopShortcut inherits Rectangle {
    in property <string> label;
    in property <string> icon-text;
    in property <image> icon;
    in property <bool> active: false;
    callback clicked();

    width: 88px;
    height: 102px;
    background: touch.has-hover ? #162031aa : transparent;
    border-radius: ShellTheme.radius-lg * 1px;
    border-width: touch.has-hover ? 1px : 0px;
    border-color: touch.has-hover ? ShellTheme.outline-strong : transparent;

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    VerticalLayout {
        padding: 8px;
        spacing: 8px;
        alignment: center;

        Rectangle {
            width: 46px;
            height: 46px;
            border-radius: 999px;
            background: root.active ? ShellTheme.accent : ShellTheme.surface-muted;
            border-width: 1px;
            border-color: root.active ? ShellTheme.accent : ShellTheme.outline;

            if root.icon.width > 0 && root.icon.height > 0: Image {
                source: root.icon;
                width: 24px;
                height: 24px;
                x: 11px;
                y: 11px;
            }

            if root.icon.width == 0 || root.icon.height == 0: Text {
                text: root.icon-text;
                color: root.active ? #1a120d : ShellTheme.text-primary;
                font-size: 12px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Text {
            text: root.label;
            color: ShellTheme.text-primary;
            font-size: 11px;
            font-weight: 700;
            horizontal-alignment: center;
            wrap: word-wrap;
        }
    }
}

component WindowGhost inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <string> icon-text;
    in property <image> icon;
    callback clicked();

    background: #121b28b0;
    border-radius: ShellTheme.radius-xl * 1px;
    border-width: 1px;
    border-color: touch.has-hover ? ShellTheme.accent : #30415688;

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    VerticalLayout {
        padding: 14px;
        spacing: 12px;

        HorizontalLayout {
            spacing: 10px;
            alignment: center;

            Rectangle {
                width: 34px;
                height: 34px;
                border-radius: 999px;
                background: ShellTheme.surface-muted;
                border-width: 1px;
                border-color: ShellTheme.outline;

                if root.icon.width > 0 && root.icon.height > 0: Image {
                    source: root.icon;
                    width: 18px;
                    height: 18px;
                    x: 8px;
                    y: 8px;
                }

                if root.icon.width == 0 || root.icon.height == 0: Text {
                    text: root.icon-text;
                    color: ShellTheme.text-primary;
                    font-size: 10px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            VerticalLayout {
                spacing: 2px;
                horizontal-stretch: 1;

                Text {
                    text: root.title;
                    color: ShellTheme.text-primary;
                    font-size: 15px;
                    font-weight: 800;
                    overflow: elide;
                }

                Text {
                    text: root.detail;
                    color: ShellTheme.text-secondary;
                    font-size: 10px;
                    overflow: elide;
                }
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: #0d152088;
            border-radius: ShellTheme.radius-lg * 1px;
            border-width: 1px;
            border-color: #25344766;
        }
    }
}

export component Desktop inherits Rectangle {
    in property <string> accent: "#4a90e2";
    in property <string> clock-text;
    in property <string> status-text: "Ready";
    in property <string> network-text: "NET";
    in property <string> power-text: "PWR";
    in property <string> audio-text: "VOL ?";
    in property <[LauncherApp]> apps;
    in property <[LauncherApp]> featured-apps;
    in property <[LauncherApp]> recent-apps;
    in property <[LauncherApp]> active-apps;
    in property <[DesktopFile]> recent-files;
    in property <string> user-name;
    in property <string> theme-name;
    in property <string> wallpaper-path;
    in property <int> app-count;
    in property <int> session-count;
    in property <int> notification-count;
    in property <bool> overview-enabled: true;
    in property <bool> split-layout: root.width >= 1120px;
    in property <bool> compact: root.width < 820px;

    callback show-launcher();
    callback show-command-surface();
    callback show-overview();
    callback launch-app(string);
    callback open-file(string);

    background: ShellTheme.background;

    Rectangle {
        x: -160px;
        y: -140px;
        width: 440px;
        height: 440px;
        background: ShellTheme.ambient-primary;
        border-radius: 999px;
        opacity: 0.16;
    }

    Rectangle {
        x: root.width - 300px;
        y: 18px;
        width: 340px;
        height: 340px;
        background: ShellTheme.ambient-secondary;
        border-radius: 999px;
        opacity: 0.12;
    }

    Rectangle {
        x: root.width * 0.33;
        y: root.height - 300px;
        width: 380px;
        height: 380px;
        background: ShellTheme.ambient-tertiary;
        border-radius: 999px;
        opacity: 0.08;
    }

    Rectangle {
        x: 18px;
        y: 14px;
        width: root.width - 36px;
        height: 34px;
        background: #131c286e;
        border-radius: 999px;
        border-width: 1px;
        border-color: #31435a4a;

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            spacing: 8px;
            alignment: center;

            Rectangle {
                width: 20px;
                height: 20px;
                background: ShellTheme.accent;
                border-radius: 999px;
                border-width: 1px;
                border-color: ShellTheme.accent;

                Text {
                    text: "S";
                    color: #1a120d;
                    font-size: 10px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                text: "SeatShell";
                color: ShellTheme.text-primary;
                font-size: 11px;
                font-weight: 800;
            }

            Text {
                text: root.user-name;
                color: ShellTheme.text-secondary;
                font-size: 10px;
                horizontal-stretch: 1;
                overflow: elide;
            }

            ShellPill {
                label: root.theme-name;
                tone: ShellTheme.surface-accent;
                compact: true;
            }

            ShellPill {
                label: root.clock-text;
                tone: ShellTheme.surface-glow;
                compact: true;
            }
        }
    }

    if root.split-layout: Rectangle {
        x: 0px;
        y: 56px;
        width: root.width;
        height: root.height - 118px;
        background: transparent;

        if root.featured-apps.length > 0: DesktopShortcut {
            x: 28px;
            y: 28px;
            label: root.featured-apps[0].name;
            icon-text: root.featured-apps[0].icon_text;
            icon: root.featured-apps[0].icon;
            active: root.featured-apps[0].running_count > 0;
            clicked => { root.launch-app(root.featured-apps[0].id); }
        }

        if root.featured-apps.length > 1: DesktopShortcut {
            x: 28px;
            y: 142px;
            label: root.featured-apps[1].name;
            icon-text: root.featured-apps[1].icon_text;
            icon: root.featured-apps[1].icon;
            active: root.featured-apps[1].running_count > 0;
            clicked => { root.launch-app(root.featured-apps[1].id); }
        }

        if root.featured-apps.length > 2: DesktopShortcut {
            x: 28px;
            y: 256px;
            label: root.featured-apps[2].name;
            icon-text: root.featured-apps[2].icon_text;
            icon: root.featured-apps[2].icon;
            active: root.featured-apps[2].running_count > 0;
            clicked => { root.launch-app(root.featured-apps[2].id); }
        }
        Rectangle {
            x: root.width / 2 - 220px;
            y: 126px;
            width: 440px;
            height: 220px;
            background: #121b28a8;
            border-radius: ShellTheme.radius-xl * 1px;
            border-width: 1px;
            border-color: #30415688;

            if root.active-apps.length == 0: VerticalLayout {
                padding: 20px;
                spacing: 12px;

                Text {
                    text: "Workspace ready";
                    color: ShellTheme.text-primary;
                    font-size: 22px;
                    font-weight: 800;
                }

                Text {
                    text: "A quiet desktop with room to begin.";
                    color: ShellTheme.text-secondary;
                    font-size: 11px;
                }

                Rectangle {
                    vertical-stretch: 1;
                    background: #0d152088;
                    border-radius: ShellTheme.radius-lg * 1px;
                    border-width: 1px;
                    border-color: #25344766;

                    VerticalLayout {
                        padding: 16px;
                        spacing: 10px;

                        Text {
                            text: "Launch something and active windows will settle here.";
                            color: ShellTheme.text-primary;
                            font-size: 15px;
                            font-weight: 700;
                            wrap: word-wrap;
                        }

                        Text {
                            text: "Use the launcher for browsing and the surface for quick shell actions.";
                            color: ShellTheme.text-secondary;
                            font-size: 11px;
                            wrap: word-wrap;
                        }

                        Rectangle { vertical-stretch: 1; background: transparent; }

                        HorizontalLayout {
                            spacing: 8px;

                            ShellAction {
                                label: "Launcher";
                                icon-text: "A";
                                compact: true;
                                clicked => {
                                    root.show-launcher();
                                }
                            }

                            ShellAction {
                                label: "Surface";
                                icon-text: "C";
                                compact: true;
                                clicked => {
                                    root.show-command-surface();
                                }
                            }
                        }
                    }
                }
            }

            if root.active-apps.length > 0: WindowGhost {
                x: 16px;
                y: 16px;
                width: parent.width - 32px;
                height: parent.height - 32px;
                title: root.active-apps[0].name;
                detail: root.active-apps[0].detail;
                icon-text: root.active-apps[0].icon_text;
                icon: root.active-apps[0].icon;
                clicked => {
                    root.launch-app(root.active-apps[0].id);
                }
            }
        }

        if root.active-apps.length > 1: WindowGhost {
            x: root.width / 2 + 128px;
            y: 304px;
            width: 220px;
            height: 118px;
            title: root.active-apps[1].name;
            detail: root.active-apps[1].detail;
            icon-text: root.active-apps[1].icon_text;
            icon: root.active-apps[1].icon;
            clicked => {
                root.launch-app(root.active-apps[1].id);
            }
        }
    }

    if !root.split-layout: ScrollView {
        x: 12px;
        y: 56px;
        width: root.width - 24px;
        height: root.height - 118px;
        viewport-width: self.width;

        VerticalLayout {
            spacing: 12px;

            Rectangle {
                background: transparent;
                height: 116px;

                if root.active-apps.length == 0: Text {
                    text: "Desktop is quiet.";
                    color: ShellTheme.text-primary;
                    font-size: 18px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    width: parent.width;
                    y: 18px;
                }

                if root.active-apps.length == 0: Text {
                    text: "Launch something and active windows will settle here.";
                    color: ShellTheme.text-secondary;
                    font-size: 11px;
                    horizontal-alignment: center;
                    width: parent.width;
                    y: 48px;
                }
            }

            HorizontalLayout {
                spacing: 8px;

                for app in root.featured-apps: DesktopShortcut {
                    label: app.name;
                    icon-text: app.icon_text;
                    icon: app.icon;
                    active: app.running_count > 0;
                    clicked => {
                        root.launch-app(app.id);
                    }
                }
            }

            for app in root.active-apps: WindowGhost {
                height: 158px;
                title: app.name;
                detail: app.detail;
                icon-text: app.icon_text;
                icon: app.icon;
                clicked => {
                    root.launch-app(app.id);
                }
            }
        }
    }
}
