import { ShellTheme } from "shell-theme.slint";

export component AppRow inherits Rectangle {
    in property <string> name;
    in property <string> detail;
    in property <string> icon-text;
    in property <image> icon;
    in property <string> accent: "#4a90e2";
    in property <bool> selected: false;
    in property <bool> favorite: false;
    in property <int> running-count: 0;
    in property <bool> show-favorite-toggle: false;

    callback clicked();
    callback toggle-favorite();

    height: 64px;
    border-radius: ShellTheme.radius-lg * 1px;
    border-width: 1px;
    border-color: root.selected || touch.has-hover ? ShellTheme.accent : ShellTheme.outline;
    background: root.selected
        ? ShellTheme.surface-accent
        : touch.has-hover
            ? ShellTheme.surface-glow
            : ShellTheme.surface;

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 12px;
        alignment: center;

        Rectangle {
            width: 42px;
            height: 42px;
            background: root.selected || touch.has-hover ? ShellTheme.accent : ShellTheme.surface-muted;
            border-radius: 999px;
            border-width: 1px;
            border-color: root.selected || touch.has-hover ? ShellTheme.accent : ShellTheme.outline;

            if root.icon.width > 0 && root.icon.height > 0: Image {
                source: root.icon;
                width: 22px;
                height: 22px;
                x: 10px;
                y: 10px;
            }

            if root.icon.width == 0 || root.icon.height == 0: Text {
                text: root.icon-text;
                color: root.selected || touch.has-hover ? #1a120d : ShellTheme.text-primary;
                font-size: 12px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        VerticalLayout {
            padding-top: 8px;
            padding-bottom: 8px;
            spacing: 3px;
            horizontal-stretch: 1;

            Text {
                text: root.name;
                color: ShellTheme.text-primary;
                font-size: 14px;
                font-weight: 800;
                overflow: elide;
                horizontal-stretch: 1;
            }

            Text {
                text: root.detail;
                color: ShellTheme.text-muted;
                font-size: 11px;
                overflow: elide;
                horizontal-stretch: 1;
            }
        }

        if root.running-count > 0: Rectangle {
            width: root.running-count > 1 ? 28px : 18px;
            height: 20px;
            background: root.running-count > 1 ? ShellTheme.accent-soft : transparent;
            border-radius: 999px;
            border-width: root.running-count > 1 ? 1px : 0px;
            border-color: ShellTheme.accent;

            Text {
                text: root.running-count > 1 ? root.running-count + "" : "•";
                color: root.running-count > 1 ? ShellTheme.text-accent : ShellTheme.text-primary;
                font-size: root.running-count > 1 ? 10px : 14px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Rectangle {
            width: 22px;
            height: 22px;
            background: transparent;
            opacity: touch.has-hover || root.selected ? 1 : 0.55;

            Text {
                text: ">";
                color: touch.has-hover || root.selected ? ShellTheme.text-accent : ShellTheme.text-secondary;
                font-size: 12px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        if root.show-favorite-toggle: Rectangle {
            width: 60px;
            height: 30px;
            background: root.favorite ? ShellTheme.surface-accent : ShellTheme.surface-muted;
            border-radius: 999px;
            border-width: 1px;
            border-color: root.favorite ? ShellTheme.accent : ShellTheme.outline;

            pin-touch := TouchArea {
                clicked => {
                    root.toggle-favorite();
                }
            }

            Text {
                text: root.favorite ? "Kept" : "Pin";
                color: root.favorite ? ShellTheme.text-accent : ShellTheme.text-primary;
                font-size: 11px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
