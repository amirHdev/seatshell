import { LauncherApp } from "launcher.slint";
import { AppRow } from "app-row.slint";
import { ShellTheme } from "shell-theme.slint";
import { ShellAction, ShellPill } from "shell-widgets.slint";
import { ScrollView } from "std-widgets.slint";

export component CommandSurface inherits Rectangle {
    in property <string> accent: "#4a90e2";
    in property <bool> overview-enabled: true;
    in property <[LauncherApp]> featured-apps;
    in property <[LauncherApp]> recent-apps;

    callback close();
    callback show-launcher();
    callback show-overview();
    callback launch-app(string);

    background: #05080dbb;

    touch := TouchArea {
        clicked => {
            root.close();
        }
    }

    Rectangle {
        x: min(24px, root.width * 0.03);
        y: min(24px, root.height * 0.03);
        width: min(root.width - 48px, 440px);
        height: min(root.height - 48px, 520px);
        background: ShellTheme.background-elevated;
        border-radius: ShellTheme.radius-lg * 1px;
        border-width: 1px;
        border-color: ShellTheme.outline;

        VerticalLayout {
            padding: 16px;
            spacing: 12px;

            HorizontalLayout {
                spacing: 8px;
                alignment: center;

                VerticalLayout {
                    spacing: 2px;
                    horizontal-stretch: 1;

                    Text {
                        text: "Command Surface";
                        color: ShellTheme.text-primary;
                        font-size: 18px;
                        font-weight: 800;
                    }

                    Text {
                        text: "Fast shell controls and a few trusted launch targets.";
                        color: ShellTheme.text-secondary;
                        font-size: 12px;
                    }
                }

                ShellPill {
                    label: "Desktop";
                    compact: true;
                }

                ShellAction {
                    label: "Close";
                    icon-text: "X";
                    compact: true;
                    clicked => {
                        root.close();
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: ShellTheme.outline;
            }

            HorizontalLayout {
                spacing: 8px;

                ShellAction {
                    label: "Launcher";
                    icon-text: "A";
                    compact: true;
                    clicked => {
                        root.show-launcher();
                    }
                }

                if root.overview-enabled: ShellAction {
                    label: "Overview";
                    icon-text: "U";
                    compact: true;
                    clicked => {
                        root.show-overview();
                    }
                }
            }

            ScrollView {
                vertical-stretch: 1;
                viewport-width: self.width;

                VerticalLayout {
                    spacing: 14px;

                    if root.featured-apps.length > 0: Rectangle {
                        background: transparent;

                        VerticalLayout {
                            spacing: 8px;

                            Text {
                                text: "Pinned";
                                color: ShellTheme.text-secondary;
                                font-size: 12px;
                                font-weight: 700;
                            }

                            for app in root.featured-apps: AppRow {
                                name: app.name;
                                detail: app.detail;
                                icon-text: app.icon_text;
                                icon: app.icon;
                                favorite: app.favorite;
                                accent: root.accent;
                                clicked => {
                                    root.launch-app(app.id);
                                }
                            }
                        }
                    }

                    if root.recent-apps.length > 0: Rectangle {
                        background: transparent;

                        VerticalLayout {
                            spacing: 8px;

                            Text {
                                text: "Recent";
                                color: ShellTheme.text-secondary;
                                font-size: 12px;
                                font-weight: 700;
                            }

                            for app in root.recent-apps: AppRow {
                                name: app.name;
                                detail: app.detail;
                                icon-text: app.icon_text;
                                icon: app.icon;
                                favorite: app.favorite;
                                accent: root.accent;
                                clicked => {
                                    root.launch-app(app.id);
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
