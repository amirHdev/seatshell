import { ScrollView } from "std-widgets.slint";
import { ShellTheme } from "shell-theme.slint";
import { ShellAction, ShellPill } from "shell-widgets.slint";

export struct NotificationEntry {
    id: int,
    title: string,
    body: string,
    urgency: string,
}

export component NotificationCenter inherits Rectangle {
    in property <[NotificationEntry]> notifications;
    callback clear-all();
    callback dismiss-notification(int);
    callback close();

    background: ShellTheme.background-veil;

    Rectangle {
        x: max(12px, root.width - min(360px, root.width - 24px) - 12px);
        y: 12px;
        width: min(360px, root.width - 24px);
        height: root.height - 24px;
        background: ShellTheme.background-elevated;
        border-radius: ShellTheme.radius-xl * 1px;
        border-width: 1px;
        border-color: ShellTheme.outline;

        VerticalLayout {
            padding: 14px;
            spacing: 10px;

            HorizontalLayout {
                spacing: 8px;
                alignment: center;

                VerticalLayout {
                    spacing: 2px;
                    horizontal-stretch: 1;

                    Text {
                        text: "Notifications";
                        color: ShellTheme.text-primary;
                        font-size: 18px;
                        font-weight: 800;
                    }

                    Text {
                        text: "A calmer log of movement, warnings, and system replies.";
                        color: ShellTheme.text-secondary;
                        font-size: 12px;
                    }
                }

                ShellPill {
                    label: root.notifications.length + "";
                    compact: true;
                }

                ShellAction {
                    label: "Clear";
                    icon-text: "-";
                    compact: true;
                    clicked => {
                        root.clear-all();
                    }
                }

                ShellAction {
                    label: "";
                    icon-text: "X";
                    compact: true;
                    clicked => {
                        root.close();
                    }
                }
            }

            Rectangle {
                height: 1px;
                background: ShellTheme.outline;
            }

            if root.notifications.length == 0: Rectangle {
                vertical-stretch: 1;
                background: ShellTheme.surface;
                border-radius: ShellTheme.radius-md * 1px;
                border-width: 1px;
                border-color: ShellTheme.outline;

                VerticalLayout {
                    padding: 14px;
                    spacing: 8px;
                    alignment: center;

                    Text {
                        text: "No notifications";
                        color: ShellTheme.text-primary;
                        font-size: 15px;
                        font-weight: 700;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "When apps or shell services speak up, they land here in a cleaner visual queue.";
                        color: ShellTheme.text-secondary;
                        font-size: 11px;
                        wrap: word-wrap;
                        horizontal-alignment: center;
                    }
                }
            }

            if root.notifications.length > 0: ScrollView {
                vertical-stretch: 1;
                viewport-width: self.width;

                VerticalLayout {
                    spacing: 8px;

                    for notification in root.notifications: Rectangle {
                        background: ShellTheme.surface;
                        border-radius: ShellTheme.radius-md * 1px;
                        border-width: 1px;
                        border-color: notification.urgency == "critical"
                            ? ShellTheme.accent
                            : ShellTheme.outline;

                        VerticalLayout {
                            padding: 12px;
                            spacing: 8px;

                            Rectangle {
                                height: 2px;
                                background: notification.urgency == "critical"
                                    ? ShellTheme.accent
                                    : notification.urgency == "normal"
                                        ? ShellTheme.surface-glow
                                        : ShellTheme.surface-muted;
                            }

                            HorizontalLayout {
                                spacing: 8px;
                                alignment: center;

                                Text {
                                    text: notification.title;
                                    color: ShellTheme.text-primary;
                                    font-size: 13px;
                                    font-weight: 700;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }

                                ShellPill {
                                    label: notification.urgency;
                                    tone: notification.urgency == "critical"
                                        ? ShellTheme.surface-accent
                                        : ShellTheme.surface-muted;
                                    compact: true;
                                }

                                ShellAction {
                                    label: "";
                                    icon-text: "X";
                                    compact: true;
                                    clicked => {
                                        root.dismiss-notification(notification.id);
                                    }
                                }
                            }

                            if notification.body != "": Text {
                                text: notification.body;
                                color: ShellTheme.text-secondary;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }
        }
    }
}
