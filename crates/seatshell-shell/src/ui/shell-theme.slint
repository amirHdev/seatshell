export global ShellTheme {
    in property <color> background: #070a0f;
    in property <color> background-elevated: #0d1118;
    in property <color> surface: #121821;
    in property <color> surface-muted: #171f2b;
    in property <color> surface-strong: #1d2736;
    in property <color> outline: #273243;
    in property <color> outline-strong: #344764;
    in property <color> text-primary: #edf2f8;
    in property <color> text-secondary: #aeb9c8;
    in property <color> text-muted: #8795a8;
    in property <color> accent: #6ab0ff;
    in property <color> accent-soft: #14263d;
    in property <color> success: #4ad295;
    in property <int> space-xs: 6;
    in property <int> space-sm: 10;
    in property <int> space-md: 14;
    in property <int> space-lg: 20;
    in property <int> radius-sm: 6;
    in property <int> radius-md: 8;
    in property <int> radius-lg: 12;
}
